    "version": "0.2.0",
    "configurations": [
        {
            "name": "Firefox - Dev Server",
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/app",
            "skipFiles": ["<node_internals>/**"],
            "firefoxArgs": ["-profile", "/home/knallfrosch/snap/firefox/common/.mozilla/firefox/eborkysg.develop"],
            "preLaunchTask": "start all",
            "tmpDir": "${workspaceFolder}/.vscode/firefox-debug"
        }
    ]
}