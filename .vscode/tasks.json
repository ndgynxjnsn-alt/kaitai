{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "vite dev",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE v\\d+\\.\\d+\\.\\d+ ready in",
                    "endsPattern": "^(?!.*)"
                }
            }
        }
    ]
}
